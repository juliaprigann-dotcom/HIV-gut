  category = "H"
)

# List all CSV files in the folder
csv_files <- list.files(input_folder, pattern = "\\.csv$", full.names = TRUE)

# Function to process a single CSV
process_gsea <- function(file_path) {
  # Extract a base name for output
  base_name <- tools::file_path_sans_ext(basename(file_path))
  
  # Read CSV
  dge_df <- read_csv(file_path)
  
  # Map gene symbols
  dge_mapped_df <- dge_df %>%
    mutate(
      gene_symbol_mapped = mapIds(
        org.Hs.eg.db,
        keys = gene,  
        column = "SYMBOL",
        keytype = "SYMBOL",
        multiVals = "first"
      )
    ) %>%
    filter(!is.na(gene_symbol_mapped))
  
  # Remove duplicates (keep largest abs log2FC)
  filtered_dge_mapped_df <- dge_mapped_df %>%
    arrange(desc(abs(avg_log2FC))) %>%
    distinct(gene_symbol_mapped, .keep_all = TRUE)
  
  # Create ranking metric
  rank_metric <- -log10(filtered_dge_mapped_df$p_val) * sign(filtered_dge_mapped_df$avg_log2FC)
  names(rank_metric) <- filtered_dge_mapped_df$gene_symbol_mapped
  rank_metric <- sort(rank_metric, decreasing = TRUE)
  
  # Run GSEA
  gsea_results <- GSEA(
    geneList = rank_metric,
    minGSSize = 25,
    maxGSSize = 1000,
    pvalueCutoff = 0.05,
    eps = 0,
    seed = TRUE,
    pAdjustMethod = "fdr",
    TERM2GENE = dplyr::select(mm_hallmark_sets, gs_name, gene_symbol)
  )
  
  # Convert to data frame
  gsea_result_df <- data.frame(gsea_results@result)
  
  # Write output CSV
  out_file <- file.path(output_folder, paste0(base_name, "_GSEA_results.csv"))
  write_csv(gsea_result_df, out_file)
  
  message("Processed: ", base_name)
  
  return(gsea_result_df)
}

# Run for all CSV files
gsea_list <- map(csv_files, process_gsea)

